<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gloucester Bathroom Fitters — Complete Bathroom Installations</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Raleway:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #1B2A3B;
    --warm-white: #F8F7F4;
    --gold: #C9A96E;
    --grey: #6B7280;
    --stone: #EDE8E0;
    --navy-light: #243548;
    --gold-hover: #b8944f;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    background: var(--warm-white);
    color: var(--navy);
    font-size: 16px;
    line-height: 1.8;
    overflow-x: hidden;
  }

  /* ── NAVIGATION ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    background: var(--navy);
    z-index: 1000;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    border-bottom: 1px solid rgba(201,169,110,0.2);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    cursor: pointer;
  }

  .logo-icon {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .logo-text span:first-child {
    font-family: 'Raleway', sans-serif;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.18em;
    color: #fff;
    text-transform: uppercase;
  }

  .logo-text span:last-child {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--gold);
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    transition: color 0.2s;
    cursor: pointer;
    white-space: nowrap;
  }

  .nav-links a:hover, .nav-links a.active { color: var(--gold); }

  .nav-cta {
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold) !important;
    padding: 8px 20px;
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 11px !important;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }

  .nav-cta:hover {
    background: var(--gold) !important;
    color: var(--navy) !important;
  }

  /* ── PAGES ── */
  .page { display: none; padding-top: 72px; min-height: 100vh; }
  .page.active { display: block; }

  /* ── GOLD RULE ── */
  .gold-rule {
    width: 60px;
    height: 1px;
    background: var(--gold);
    margin: 0 auto 28px;
  }

  .gold-rule.left { margin: 0 0 28px; }

  /* ── SECTION WRAPPER ── */
  .section { padding: 80px 40px; max-width: 1200px; margin: 0 auto; }
  .section-full { padding: 80px 40px; }
  .section-bg { background: var(--stone); }
  .section-navy { background: var(--navy); color: var(--warm-white); }

  /* ── EYEBROW ── */
  .eyebrow {
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 14px;
    display: block;
  }

  h1, h2, h3 { font-family: 'Playfair Display', serif; font-weight: 400; line-height: 1.2; }
  h1 { font-size: clamp(36px, 5vw, 64px); }
  h2 { font-size: clamp(28px, 3.5vw, 44px); }
  h3 { font-size: 22px; }

  p { color: var(--grey); margin-bottom: 1em; font-weight: 300; }

  /* ── HOME HERO ── */
  .hero {
    height: 88vh;
    background: linear-gradient(to bottom, rgba(27,42,59,0.42) 0%, rgba(27,42,59,0.28) 60%), 
                url('data:image/jpeg;base64,') center/cover no-repeat;
    display: flex;
    align-items: center;
    padding: 0 60px;
    position: relative;
    margin-top: 0;
  }

  .hero-content { max-width: 640px; }

  .hero h1 { color: #fff; margin-bottom: 20px; line-height: 1.1; }

  .hero-sub {
    color: rgba(255,255,255,0.85);
    font-size: 17px;
    font-weight: 300;
    font-style: italic;
    font-family: 'Playfair Display', serif;
    margin-bottom: 36px;
    line-height: 1.5;
  }

  .hero-badges {
    display: flex;
    gap: 28px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .hero-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-badge strong {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    color: var(--gold);
    font-weight: 400;
    line-height: 1;
  }

  .hero-badge span {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    font-weight: 400;
    margin-top: 4px;
  }

  .hero-divider {
    width: 1px;
    height: 40px;
    background: rgba(201,169,110,0.4);
    align-self: center;
  }

  /* ── BUTTONS ── */
  .btn-primary {
    display: inline-block;
    background: var(--gold);
    color: var(--navy);
    padding: 14px 36px;
    font-family: 'Raleway', sans-serif;
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-primary:hover { background: var(--gold-hover); transform: translateY(-1px); }

  .btn-outline {
    display: inline-block;
    background: transparent;
    color: var(--navy);
    padding: 13px 34px;
    font-family: 'Raleway', sans-serif;
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid var(--navy);
    transition: all 0.2s;
  }

  .btn-outline:hover { background: var(--navy); color: #fff; }

  .btn-outline-gold {
    display: inline-block;
    background: transparent;
    color: var(--gold);
    padding: 13px 34px;
    font-family: 'Raleway', sans-serif;
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid var(--gold);
    transition: all 0.2s;
  }

  .btn-outline-gold:hover { background: var(--gold); color: var(--navy); }

  /* ── WHY CHOOSE US ── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 48px;
    margin-top: 56px;
  }

  .why-item { position: relative; padding-left: 0; }

  .why-marker {
    width: 32px;
    height: 1px;
    background: var(--gold);
    margin-bottom: 20px;
  }

  .why-item h3 {
    font-size: 18px;
    margin-bottom: 12px;
    font-weight: 400;
  }

  /* ── TRUST BAR ── */
  .trust-bar {
    background: var(--navy);
    padding: 32px 40px;
    display: flex;
    justify-content: center;
    gap: 60px;
    align-items: center;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .trust-item strong {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    color: var(--gold);
    font-weight: 400;
  }

  .trust-item span {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    font-weight: 400;
  }

  .trust-divider {
    width: 1px;
    height: 36px;
    background: rgba(201,169,110,0.25);
  }

  /* ── CTA BAND ── */
  .cta-band {
    background: var(--stone);
    padding: 72px 40px;
    text-align: center;
  }

  .cta-band h2 { margin-bottom: 14px; }
  .cta-band p { max-width: 500px; margin: 0 auto 32px; }

  /* ── SERVICES ── */
  .service-intro { max-width: 680px; }
  
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1px;
    margin: 56px 0;
    background: var(--stone);
    border: 1px solid var(--stone);
  }

  .service-card {
    background: var(--warm-white);
    padding: 36px 32px;
    transition: background 0.2s;
  }

  .service-card:hover { background: #f0ede8; }

  .service-num {
    font-family: 'Playfair Display', serif;
    font-size: 36px;
    color: var(--stone);
    font-weight: 400;
    line-height: 1;
    margin-bottom: 16px;
  }

  .service-card h3 {
    font-size: 17px;
    margin-bottom: 10px;
    font-weight: 400;
  }

  .service-card p { font-size: 14px; margin: 0; color: var(--grey); }

  /* ── SPECIALISMS ── */
  .specialisms {
    background: var(--navy);
    color: var(--warm-white);
    padding: 80px 40px;
  }

  .spec-inner { max-width: 1200px; margin: 0 auto; }
  .spec-inner .eyebrow { color: var(--gold); }
  .spec-inner h2 { color: var(--warm-white); margin-bottom: 48px; }

  .spec-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 40px;
  }

  .spec-item { border-left: 1px solid rgba(201,169,110,0.3); padding-left: 24px; }
  .spec-item h3 { font-size: 17px; color: var(--warm-white); margin-bottom: 10px; font-weight: 400; }
  .spec-item p { color: rgba(255,255,255,0.6); font-size: 14px; margin: 0; }

  .dont-do {
    background: var(--stone);
    padding: 40px;
    margin-top: 48px;
    max-width: 640px;
  }

  .dont-do h3 { font-size: 16px; margin-bottom: 10px; color: var(--navy); }
  .dont-do p { font-size: 14px; margin: 0; color: var(--grey); }

  /* ── GALLERY ── */
  .gallery-filters {
    display: flex;
    gap: 8px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 8px 22px;
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid var(--stone);
    background: transparent;
    color: var(--grey);
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn:hover, .filter-btn.active {
    border-color: var(--navy);
    background: var(--navy);
    color: #fff;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 220px;
    gap: 10px;
  }

  .gallery-item {
    overflow: hidden;
    cursor: pointer;
    position: relative;
    background: var(--stone);
  }

  .gallery-item img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .gallery-item:hover img { transform: scale(1.04); }

  .gallery-item .overlay {
    position: absolute; inset: 0;
    background: rgba(27,42,59,0);
    transition: background 0.3s;
    display: flex;
    align-items: flex-end;
    padding: 16px;
  }

  .gallery-item:hover .overlay { background: rgba(27,42,59,0.45); }

  .gallery-item .overlay-label {
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 12px;
    letter-spacing: 0.1em;
    color: #fff;
    opacity: 0;
    transition: opacity 0.3s;
    text-transform: uppercase;
  }

  .gallery-item:hover .overlay-label { opacity: 1; }

  .span-2 { grid-column: span 2; }
  .span-row-2 { grid-row: span 2; }

  .gallery-placeholder {
    width: 100%; height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Raleway', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: rgba(107,114,128,0.5);
    text-transform: uppercase;
    flex-direction: column;
    gap: 8px;
  }

  .gallery-placeholder svg { opacity: 0.3; }

  .gallery-intro-text {
    max-width: 600px;
    margin-bottom: 14px;
  }

  /* ── LIGHTBOX ── */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(27,42,59,0.95);
    z-index: 2000;
    align-items: center;
    justify-content: center;
  }

  .lightbox.open { display: flex; }
  .lightbox-close {
    position: absolute;
    top: 24px; right: 32px;
    color: rgba(255,255,255,0.7);
    font-size: 32px;
    cursor: pointer;
    background: none;
    border: none;
    line-height: 1;
    transition: color 0.2s;
  }
  .lightbox-close:hover { color: var(--gold); }

  .lightbox-img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    display: block;
  }

  /* ── ABOUT ── */
  .about-hero-band {
    background: var(--navy);
    padding: 80px 40px 0;
    overflow: hidden;
  }

  .about-inner { max-width: 1200px; margin: 0 auto; }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: stretch;
  }

  .about-story h2 { color: #fff; margin-bottom: 24px; }
  .about-story .eyebrow { color: var(--gold); }
  .about-story p { color: rgba(255,255,255,0.7); }

  .about-quote-pull {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 22px;
    color: var(--gold);
    line-height: 1.45;
    border-left: 2px solid var(--gold);
    padding-left: 24px;
    margin: 36px 0;
  }

  .about-image-block {
    position: relative;
    padding-top: 0;
    display: flex;
    flex-direction: column;
  }

  .about-image-mock {
    width: 100%;
    flex: 1;
    min-height: 480px;
    background: var(--navy);
    display: block;
    overflow: hidden;
    border: none;
    position: relative;
  }

  .about-credentials {
    background: var(--warm-white);
    padding: 36px 40px;
    margin-top: 0;
    margin-left: 0;
    position: relative;
    z-index: 1;
    border-top: 3px solid var(--gold);
  }

  .cred-row {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--stone);
    font-size: 14px;
  }

  .cred-row:last-child { border-bottom: none; }

  .cred-label {
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--grey);
  }

  .cred-value { color: var(--navy); font-weight: 300; }

  /* ── TESTIMONIALS SECTION ── */
  .testimonials-section { background: var(--stone); padding: 80px 40px; }
  .test-inner { max-width: 1200px; margin: 0 auto; }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 32px;
    margin-top: 48px;
  }

  .testimonial-card {
    background: var(--warm-white);
    padding: 36px 32px;
    position: relative;
  }

  .stars {
    color: var(--gold);
    letter-spacing: 2px;
    font-size: 14px;
    margin-bottom: 16px;
    display: block;
  }

  .testimonial-card blockquote {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 16px;
    line-height: 1.65;
    color: var(--navy);
    margin-bottom: 24px;
    quotes: none;
  }

  .testimonial-author {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--grey);
    font-weight: 400;
  }

  .google-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 48px;
    padding: 20px 28px;
    background: var(--warm-white);
    display: inline-flex;
    border: 1px solid rgba(201,169,110,0.3);
  }

  .google-badge .g-stars { color: var(--gold); font-size: 18px; letter-spacing: 2px; }
  .google-badge .g-text { font-size: 13px; color: var(--grey); }
  .google-badge .g-text strong { color: var(--navy); font-weight: 500; display: block; font-family: 'Playfair Display', serif; font-size: 15px; }

  /* ── HOW WE WORK ── */
  .how-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 40px;
    margin-top: 48px;
    counter-reset: steps;
  }

  .how-step { position: relative; }

  .step-num {
    font-family: 'Playfair Display', serif;
    font-size: 48px;
    color: var(--stone);
    font-weight: 400;
    line-height: 1;
    margin-bottom: 16px;
  }

  .how-step h3 { font-size: 17px; margin-bottom: 10px; font-weight: 400; }

  /* ── CONTACT ── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 80px;
    align-items: start;
  }

  .contact-process { }

  .process-step {
    display: flex;
    gap: 24px;
    margin-bottom: 40px;
    align-items: flex-start;
  }

  .process-num {
    width: 36px;
    height: 36px;
    border: 1px solid var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    color: var(--gold);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .process-step h3 { font-size: 17px; margin-bottom: 6px; font-weight: 400; }
  .process-step p { font-size: 14px; margin: 0; }

  /* ── CONTACT FORM ── */
  .contact-form-wrap {
    background: var(--stone);
    padding: 48px 40px;
  }

  .form-title {
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    margin-bottom: 8px;
    font-weight: 400;
  }

  .form-subtitle {
    font-size: 13px;
    color: var(--grey);
    margin-bottom: 32px;
  }

  .form-group { margin-bottom: 20px; }

  .form-group label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--grey);
    margin-bottom: 8px;
    font-weight: 400;
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid rgba(27,42,59,0.15);
    background: var(--warm-white);
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    font-size: 15px;
    color: var(--navy);
    outline: none;
    transition: border-color 0.2s;
    appearance: none;
  }

  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    border-color: var(--gold);
  }

  .form-group textarea { height: 120px; resize: vertical; }

  .form-2col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-submit {
    width: 100%;
    background: var(--navy);
    color: #fff;
    padding: 16px;
    font-family: 'Raleway', sans-serif;
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 8px;
  }

  .form-submit:hover { background: var(--gold); color: var(--navy); }

  .contact-details {
    margin-top: 48px;
  }

  .contact-details h3 { font-size: 18px; margin-bottom: 24px; font-weight: 400; }

  .contact-row {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-bottom: 20px;
    font-size: 15px;
  }

  .contact-icon {
    width: 40px; height: 40px;
    border: 1px solid var(--stone);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--gold);
    font-size: 18px;
  }

  .contact-row a { color: var(--navy); text-decoration: none; font-weight: 300; }
  .contact-row a:hover { color: var(--gold); }

  .assurance {
    margin-top: 40px;
    padding: 20px 24px;
    border-left: 2px solid var(--gold);
    background: var(--stone);
  }

  .assurance p { font-size: 13px; color: var(--grey); margin: 0; font-style: italic; }

  /* ── FULL TESTIMONIALS PAGE ── */
  .test-page-hero {
    background: var(--navy);
    padding: 64px 40px;
    text-align: center;
  }

  .test-page-hero h1 { color: #fff; }
  .test-page-hero p { color: rgba(255,255,255,0.65); max-width: 520px; margin: 16px auto 0; }

  .test-masonry {
